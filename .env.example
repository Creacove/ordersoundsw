
# Browser-Visible Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
VITE_PAYSTACK_PUBLIC_KEY=replace_with_paystack_public_key
VITE_SOLANA_NETWORK=devnet
VITE_SOLANA_PLATFORM_FEE_BPS=2000
VITE_DEVNET_RPC_ENDPOINT=https://api.devnet.solana.com
VITE_MAINNET_RPC_ENDPOINT=https://api.mainnet-beta.solana.com
VITE_PLATFORM_WALLET=replace_with_platform_wallet
VITE_PLATFORM_WALLET_MAINNET=replace_with_mainnet_platform_wallet
VITE_ENABLE_GUEST_CART=false
VITE_ENABLE_REFERRALS=false
VITE_ENABLE_EXPERIMENTAL_ROUTES=false

# Server-Only Secrets
# Configure these in Supabase Edge Function secrets instead of a client env file.
# PAYSTACK_SECRET_KEY_LIVE=replace_with_live_secret_key
# PAYSTACK_PLATFORM_FEE_BPS=1000
# PAYSTACK_PAYOUT_MAX_ATTEMPTS=8
# SOLANA_PLATFORM_FEE_BPS=2000
# SOLANA_PLATFORM_WALLET=replace_with_platform_wallet
# SOLANA_PLATFORM_WALLET_MAINNET=replace_with_mainnet_platform_wallet
# SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
# SOLANA_RPC_URL=replace_with_private_rpc_if_needed
